#!/bin/bash
# OpenRouter multi-model CLI for agents and skills.
# Canonical source lives in carl-tools/bin/agent (agent-skills repo).
# ~/.claude/bin/agent is a thin wrapper that calls this.
#
# Browse models: https://openrouter.ai/models
set -euo pipefail

source ~/.secrets 2>/dev/null || true

# --- Model Tiers (curate to your taste) ----------------
# Prices are per million tokens (input/output). Updated 2026-05.
# Browse: https://openrouter.ai/models?output_modalities=text
# Refresh the list: source ~/.secrets && curl -s https://openrouter.ai/api/v1/models \
#   -H "Authorization: Bearer ${OPENROUTER_API_KEY}" | python3 -c "
#   import json,sys,datetime; d=json.load(sys.stdin)['data']
#   d=[m for m in d if 'text' in m.get('architecture',{}).get('output_modalities',[])]
#   d.sort(key=lambda m:m.get('created',0),reverse=True)
#   [print(datetime.datetime.fromtimestamp(m['created']).strftime('%Y-%m-%d'),
#     m['id'], m.get('context_length',0)//1000,'k',
#     '\$%.2f/\$%.2f'%(float(m.get('pricing',{}).get('prompt',0))*1e6,
#                      float(m.get('pricing',{}).get('completion',0))*1e6))
#    for m in d[:60]]"
# ~ prefix = auto-updating "latest" alias — always tracks newest version.
#
# Default — fast workhorse for daily use
MODEL_DEFAULT="~google/gemini-flash-latest"  # $0.50/$3.00 · 1M ctx · always fresh
# Alternatives for default:
#   deepseek/deepseek-v4-flash        # $0.14/$0.28 · 1M ctx · cheapest capable option
#   qwen/qwen3.6-flash                # $0.25/$1.50 · 1M ctx · newest Qwen flash
#   ~openai/gpt-mini-latest           # $0.75/$4.50 · 400k ctx · always fresh GPT mini

# --fast — ultra-low latency, blunt, good for skeptic/trickster roles
MODEL_FAST="deepseek/deepseek-v4-flash"      # $0.14/$0.28 · 1M ctx · exceptional value
# Alternatives for --fast:
#   qwen/qwen3.6-flash                # $0.25/$1.50 · 1M ctx
#   meta-llama/llama-4-scout          # $0.08/$0.30 · 327k ctx
#   inclusionai/ling-2.6-flash        # $0.08/$0.24 · 262k ctx

# --smart — strong reasoning, code review, architecture
MODEL_SMART="deepseek/deepseek-v4-pro"       # $0.43/$0.87 · 1M ctx · astonishing value
# Alternatives for --smart:
#   ~google/gemini-pro-latest         # $2.00/$12.00 · 1M ctx · always fresh
#   ~moonshotai/kimi-latest           # $0.75/$3.50  · 262k ctx · always fresh Kimi
#   qwen/qwen3.6-plus                 # $0.33/$1.95  · 1M ctx
#   mistralai/mistral-medium-3-5      # $1.50/$7.50  · 262k ctx

# --frontier — best available, cost no object
MODEL_FRONTIER="x-ai/grok-4.3"              # $1.25/$2.50 · 1M ctx · newest Grok
# Alternatives for --frontier:
#   ~anthropic/claude-opus-latest     # $5.00/$25.00 · 1M ctx · always fresh Claude Opus
#   openai/gpt-5.5                    # $5.00/$30.00 · 1M ctx
#   openai/gpt-5.5-pro                # $30.00/$180.00 · 1M ctx · nuclear option
#   ~openai/gpt-latest                # $5.00/$30.00 · 1M ctx · always fresh GPT

# --- Shorthands — first positional arg selects model by name --------
# Usage: agent grok "question"  or  agent deepseek "question"  etc.
resolve_shorthand() {
    case "$1" in
        grok)                         echo "x-ai/grok-4.3" ;;
        deepseek|ds)                  echo "deepseek/deepseek-v4-pro" ;;
        deepseek-flash|ds-flash|dsf)  echo "deepseek/deepseek-v4-flash" ;;
        kimi)                         echo "~moonshotai/kimi-latest" ;;
        gemini)                       echo "~google/gemini-pro-latest" ;;
        flash)                        echo "~google/gemini-flash-latest" ;;
        gpt)                          echo "~openai/gpt-latest" ;;
        gpt-mini|mini)                echo "~openai/gpt-mini-latest" ;;
        claude|opus)                  echo "~anthropic/claude-opus-latest" ;;
        sonnet)                       echo "~anthropic/claude-sonnet-latest" ;;
        haiku)                        echo "~anthropic/claude-haiku-latest" ;;
        qwen)                         echo "qwen/qwen3.6-plus" ;;
        mistral)                      echo "mistralai/mistral-medium-3-5" ;;
        *)                            echo "" ;;
    esac
}
# --------------------------------------------------------------------

SYSTEM="Be concise. No preamble, no closing remarks. Answer directly. Prefer working code over explanation. Give the simplest solution that works."
MODEL="$MODEL_DEFAULT"
PROMPT_ARGS=()

show_usage() {
    cat <<EOF
Usage: agent [OPTIONS] [SHORTHAND] "your question"
       pipe content to stdin for large inputs

Tier flags:
  --fast       Ultra-fast inference (${MODEL_FAST})
  --smart      Strong reasoning (${MODEL_SMART})
  --frontier   Best available (${MODEL_FRONTIER})
  --model ID   Explicit OpenRouter model ID
  -h, --help   Show this help

Model shorthands (first positional arg):
  grok          x-ai/grok-4.3
  deepseek, ds  deepseek/deepseek-v4-pro
  dsf           deepseek/deepseek-v4-flash
  kimi          ~moonshotai/kimi-latest
  gemini        ~google/gemini-pro-latest
  flash         ~google/gemini-flash-latest
  gpt           ~openai/gpt-latest
  mini          ~openai/gpt-mini-latest
  claude, opus  ~anthropic/claude-opus-latest
  sonnet        ~anthropic/claude-sonnet-latest
  haiku         ~anthropic/claude-haiku-latest
  qwen          qwen/qwen3.6-plus
  mistral       mistralai/mistral-medium-3-5

Default model: ${MODEL_DEFAULT} (auto-tracks latest Gemini Flash)

Examples:
  agent "What is the time complexity of quicksort?"
  agent grok "Explain the CAP theorem"
  agent deepseek "Review this function for bugs"
  git diff | agent kimi "Summarize these changes"
  agent --frontier "Design a distributed rate limiter"
EOF
}

while [[ $# -gt 0 ]]; do
    case $1 in
        --fast)      MODEL="$MODEL_FAST";     shift ;;
        --smart)     MODEL="$MODEL_SMART";    shift ;;
        --frontier)  MODEL="$MODEL_FRONTIER"; shift ;;
        --model)     MODEL="$2";              shift 2 ;;
        -h|--help)   show_usage; exit 0 ;;
        *)           PROMPT_ARGS+=("$1");     shift ;;
    esac
done

# Resolve shorthand from first positional arg, if present
if [ ${#PROMPT_ARGS[@]} -gt 0 ]; then
    shorthand=$(resolve_shorthand "${PROMPT_ARGS[0]}")
    if [ -n "$shorthand" ]; then
        MODEL="$shorthand"
        PROMPT_ARGS=("${PROMPT_ARGS[@]:1}")
    fi
fi

if [ -z "${OPENROUTER_API_KEY:-}" ]; then
    echo "Error: OPENROUTER_API_KEY not set in ~/.secrets" >&2
    exit 1
fi

if [ ${#PROMPT_ARGS[@]} -gt 0 ]; then
    QUESTION="${PROMPT_ARGS[*]}"
elif [ ! -t 0 ]; then
    QUESTION=$(cat)
else
    show_usage >&2
    exit 1
fi

payload=$(python3 -c "
import json, sys
print(json.dumps({
    'model': sys.argv[1],
    'messages': [
        {'role': 'system', 'content': sys.argv[2]},
        {'role': 'user', 'content': sys.argv[3]}
    ],
    'temperature': 0.7,
    'max_tokens': 8000
}))
" "$MODEL" "$SYSTEM" "$QUESTION")

curl -s https://openrouter.ai/api/v1/chat/completions \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer ${OPENROUTER_API_KEY}" \
  -H "HTTP-Referer: https://claude.ai" \
  -H "X-Title: Claude Code" \
  -d "$payload" | python3 -c "
import sys, json
data = json.load(sys.stdin)
if 'error' in data:
    print('Error:', data['error'].get('message', data['error']), file=sys.stderr)
    sys.exit(1)
print(data['choices'][0]['message']['content'])
"
