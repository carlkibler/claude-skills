#!/bin/bash
# OpenRouter multi-model CLI for agents and skills.
# Canonical source lives in carl-tools/bin/agent (agent-skills repo).
# ~/.claude/bin/agent is a thin wrapper that calls this.
#
# Browse models: https://openrouter.ai/models
set -euo pipefail

source ~/.secrets 2>/dev/null || true

# --- Model Tiers (curate to your taste) ----------------
# Prices are per million tokens (input/output). Updated 2026-05.
# Browse: https://openrouter.ai/models?output_modalities=text
# Refresh the list: source ~/.secrets && curl -s https://openrouter.ai/api/v1/models \
#   -H "Authorization: Bearer ${OPENROUTER_API_KEY}" | python3 -c "
#   import json,sys,datetime; d=json.load(sys.stdin)['data']
#   d=[m for m in d if 'text' in m.get('architecture',{}).get('output_modalities',[])]
#   d.sort(key=lambda m:m.get('created',0),reverse=True)
#   [print(datetime.datetime.fromtimestamp(m['created']).strftime('%Y-%m-%d'),
#     m['id'], m.get('context_length',0)//1000,'k',
#     '\$%.2f/\$%.2f'%(float(m.get('pricing',{}).get('prompt',0))*1e6,
#                      float(m.get('pricing',{}).get('completion',0))*1e6))
#    for m in d[:60]]"
# ~ prefix = auto-updating "latest" alias — always tracks newest version.
#
# Default — fast workhorse for daily use
MODEL_DEFAULT="~google/gemini-flash-latest"  # $0.50/$3.00 · 1M ctx · always fresh
# Alternatives for default:
#   deepseek/deepseek-v4-flash        # $0.14/$0.28 · 1M ctx · cheapest capable option
#   qwen/qwen3.6-flash                # $0.25/$1.50 · 1M ctx · newest Qwen flash
#   ~openai/gpt-mini-latest           # $0.75/$4.50 · 400k ctx · always fresh GPT mini

# --fast — ultra-low latency, blunt, good for skeptic/trickster roles
MODEL_FAST="deepseek/deepseek-v4-flash"      # $0.14/$0.28 · 1M ctx · exceptional value
# Alternatives for --fast:
#   qwen/qwen3.6-flash                # $0.25/$1.50 · 1M ctx
#   meta-llama/llama-4-scout          # $0.08/$0.30 · 327k ctx
#   inclusionai/ling-2.6-flash        # $0.08/$0.24 · 262k ctx

# --smart — strong reasoning, code review, architecture
MODEL_SMART="deepseek/deepseek-v4-pro"       # $0.43/$0.87 · 1M ctx · astonishing value
# Alternatives for --smart:
#   ~google/gemini-pro-latest         # $2.00/$12.00 · 1M ctx · always fresh
#   ~moonshotai/kimi-latest           # $0.75/$3.50  · 262k ctx · always fresh Kimi
#   moonshotai/kimi-k2.6:latest-preview # preview route for current Kimi 2.6 build
#   qwen/qwen3.6-plus                 # $0.33/$1.95  · 1M ctx
#   mistralai/mistral-medium-3-5      # $1.50/$7.50  · 262k ctx

# --frontier — best available, cost no object
MODEL_FRONTIER="x-ai/grok-4.3"              # $1.25/$2.50 · 1M ctx · newest Grok
# Alternatives for --frontier:
#   ~anthropic/claude-opus-latest     # $5.00/$25.00 · 1M ctx · always fresh Claude Opus
#   openai/gpt-5.5                    # $5.00/$30.00 · 1M ctx
#   openai/gpt-5.5-pro                # $30.00/$180.00 · 1M ctx · nuclear option
#   ~openai/gpt-latest                # $5.00/$30.00 · 1M ctx · always fresh GPT

# --- Shorthands — first positional arg selects model by name --------
# Usage: agent grok "question"  or  agent deepseek "question"  etc.
resolve_shorthand() {
    case "$1" in
        grok)                         echo "x-ai/grok-4.3" ;;
        deepseek|ds)                  echo "deepseek/deepseek-v4-pro" ;;
        deepseek-flash|ds-flash|dsf)  echo "deepseek/deepseek-v4-flash" ;;
        kimi|kimi-latest)             echo "~moonshotai/kimi-latest" ;;
        kimi26|kimi-26|kimi-2.6)       echo "moonshotai/kimi-k2.6" ;;
        kimi-preview|kimi-latest-preview) echo "moonshotai/kimi-k2.6:latest-preview" ;;
        gemini)                       echo "~google/gemini-pro-latest" ;;
        flash)                        echo "~google/gemini-flash-latest" ;;
        gpt)                          echo "~openai/gpt-latest" ;;
        gpt-mini|mini)                echo "~openai/gpt-mini-latest" ;;
        claude|opus)                  echo "~anthropic/claude-opus-latest" ;;
        sonnet)                       echo "~anthropic/claude-sonnet-latest" ;;
        haiku)                        echo "~anthropic/claude-haiku-latest" ;;
        qwen)                         echo "qwen/qwen3.6-plus" ;;
        mistral)                      echo "mistralai/mistral-medium-3-5" ;;
        *)                            echo "" ;;
    esac
}
# --------------------------------------------------------------------

SYSTEM_DEFAULT="Be concise. No preamble, no closing remarks. Answer directly. Prefer working code over explanation. Give the simplest solution that works."
SYSTEM="$SYSTEM_DEFAULT"
MODEL="$MODEL_DEFAULT"
TEMPERATURE="0.7"
MAX_TOKENS="8000"
REQUEST_TIMEOUT="${AGENT_TIMEOUT:-180}"
PROMPT_ARGS=()
INPUT_FILES=()
READ_STDIN="auto"
VERBOSE=0
DRY_RUN=0

show_usage() {
    cat <<'USAGE'
Usage: agent [OPTIONS] [SHORTHAND] "your question"
       agent [OPTIONS] --file packet.md "review this packet"
       git diff | agent [OPTIONS] "review this diff"

Input behavior:
  Positional text becomes the main prompt.
  Piped stdin is appended automatically, even when a prompt is present.
  --file/-f PATH may be repeated; each file is appended with a filename header.

Options:
  --fast              Ultra-fast inference
  --smart             Strong reasoning
  --frontier          Best available
  --model ID          Explicit OpenRouter model ID
  --file, -f PATH     Append file contents to the prompt (aliases: --input, --context, --prompt-file; use - for stdin)
  --stdin             Require and append stdin, even with prompt/files
  --no-stdin          Ignore piped stdin
  --system TEXT       Override system prompt
  --temperature N     Sampling temperature (default 0.7)
  --max-tokens N      Max completion tokens (default 8000)
  --timeout N         HTTP request timeout seconds (default 180; env AGENT_TIMEOUT)
  --verbose           Print model/input summary to stderr before calling
  --dry-run           Print model/input summary and final prompt; do not call API
  -h, --help          Show this help

Model shorthands (first positional arg):
  grok          x-ai/grok-4.3
  deepseek, ds  deepseek/deepseek-v4-pro
  dsf           deepseek/deepseek-v4-flash
  kimi          ~moonshotai/kimi-latest
  kimi-2.6      moonshotai/kimi-k2.6
  kimi-preview  moonshotai/kimi-k2.6:latest-preview
  gemini        ~google/gemini-pro-latest
  flash         ~google/gemini-flash-latest
  gpt           ~openai/gpt-latest
  mini          ~openai/gpt-mini-latest
  claude, opus  ~anthropic/claude-opus-latest
  sonnet        ~anthropic/claude-sonnet-latest
  haiku         ~anthropic/claude-haiku-latest
  qwen          qwen/qwen3.6-plus
  mistral       mistralai/mistral-medium-3-5

Examples:
  agent "What is the time complexity of quicksort?"
  agent grok "Explain the CAP theorem"
  agent --model openai/gpt-5.5 "Design a distributed rate limiter"
  agent --file review-packet.md --smart "Find concrete bugs"
  agent @review-packet.md grok "Find concrete bugs"
  git diff | agent kimi "Review these changes"
  agent --stdin --frontier "Review the attached packet" < packet.md
USAGE
    echo
    echo "Default model: ${MODEL_DEFAULT} (auto-tracks latest Gemini Flash)"
    echo "Tier models: fast=${MODEL_FAST}; smart=${MODEL_SMART}; frontier=${MODEL_FRONTIER}"
}

need_value() {
    local opt="$1"
    if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
        echo "Error: ${opt} requires a value" >&2
        exit 2
    fi
}

while [[ $# -gt 0 ]]; do
    case $1 in
        --fast)        MODEL="$MODEL_FAST"; shift ;;
        --smart)       MODEL="$MODEL_SMART"; shift ;;
        --frontier)    MODEL="$MODEL_FRONTIER"; shift ;;
        --model)       need_value "$1" "${2:-}"; MODEL="$2"; shift 2 ;;
        --model=*)     MODEL="${1#*=}"; shift ;;
        -f|--file|--input|--context|--prompt-file) need_value "$1" "${2:-}"; INPUT_FILES+=("$2"); shift 2 ;;
        --file=*|--input=*|--context=*|--prompt-file=*) INPUT_FILES+=("${1#*=}"); shift ;;
        --stdin)       READ_STDIN="yes"; shift ;;
        --no-stdin)    READ_STDIN="no"; shift ;;
        --system)      need_value "$1" "${2:-}"; SYSTEM="$2"; shift 2 ;;
        --system=*)    SYSTEM="${1#*=}"; shift ;;
        --temperature) need_value "$1" "${2:-}"; TEMPERATURE="$2"; shift 2 ;;
        --temperature=*) TEMPERATURE="${1#*=}"; shift ;;
        --max-tokens)  need_value "$1" "${2:-}"; MAX_TOKENS="$2"; shift 2 ;;
        --max-tokens=*) MAX_TOKENS="${1#*=}"; shift ;;
        --timeout)     need_value "$1" "${2:-}"; REQUEST_TIMEOUT="$2"; shift 2 ;;
        --timeout=*)   REQUEST_TIMEOUT="${1#*=}"; shift ;;
        --verbose)     VERBOSE=1; shift ;;
        --dry-run)     DRY_RUN=1; shift ;;
        -h|--help)     show_usage; exit 0 ;;
        --)            shift; PROMPT_ARGS+=("$@"); break ;;
        -*)            echo "Error: unknown option: $1" >&2; show_usage >&2; exit 2 ;;
        @*)
            file="${1#@}"
            if [ -r "$file" ]; then
                INPUT_FILES+=("$file")
                shift
            else
                echo "Error: @file not readable: $file" >&2
                exit 2
            fi
            ;;
        *)             PROMPT_ARGS+=("$1"); shift ;;
    esac
done

# Resolve shorthand from first positional arg, if present.
if [ ${#PROMPT_ARGS[@]} -gt 0 ]; then
    shorthand=$(resolve_shorthand "${PROMPT_ARGS[0]}")
    if [ -n "$shorthand" ]; then
        MODEL="$shorthand"
        PROMPT_ARGS=("${PROMPT_ARGS[@]:1}")
    fi
fi

append_section() {
    local current="$1"
    local title="$2"
    local body="$3"
    if [ -z "$body" ]; then
        printf '%s' "$current"
        return
    fi
    if [ -n "$current" ]; then
        printf '%s\n\n--- %s ---\n%s' "$current" "$title" "$body"
    else
        printf -- '--- %s ---\n%s' "$title" "$body"
    fi
}

QUESTION=""
if [ ${#PROMPT_ARGS[@]} -gt 0 ]; then
    QUESTION="${PROMPT_ARGS[*]}"
fi

for file in "${INPUT_FILES[@]}"; do
    if [ "$file" = "-" ]; then
        if [ -t 0 ]; then
            echo "Error: --file - requested stdin, but stdin is a TTY" >&2
            exit 2
        fi
        content=$(cat)
        QUESTION=$(append_section "$QUESTION" "stdin" "$content")
        READ_STDIN="no"
    elif [ ! -r "$file" ]; then
        echo "Error: cannot read file: $file" >&2
        exit 2
    else
        content=$(cat "$file")
        QUESTION=$(append_section "$QUESTION" "file: $file" "$content")
    fi
done

if [ "$READ_STDIN" != "no" ]; then
    if [ ! -t 0 ]; then
        stdin_content=$(cat)
        if [ -n "$stdin_content" ]; then
            QUESTION=$(append_section "$QUESTION" "stdin" "$stdin_content")
        elif [ "$READ_STDIN" = "yes" ]; then
            echo "Error: --stdin requested, but stdin was empty" >&2
            exit 2
        fi
    elif [ "$READ_STDIN" = "yes" ]; then
        echo "Error: --stdin requested, but stdin is a TTY" >&2
        exit 2
    fi
fi

if [ -z "$QUESTION" ]; then
    show_usage >&2
    exit 1
fi

case "$MAX_TOKENS" in
    ''|*[!0-9]*) echo "Error: --max-tokens must be a positive integer" >&2; exit 2 ;;
esac
if [ "$MAX_TOKENS" -le 0 ]; then
    echo "Error: --max-tokens must be a positive integer" >&2
    exit 2
fi

set +e
python3 - "$TEMPERATURE" "$REQUEST_TIMEOUT" <<'PY' >/dev/null
import math
import sys
try:
    temperature = float(sys.argv[1])
    timeout = float(sys.argv[2])
except ValueError:
    sys.exit(2)
if not math.isfinite(temperature) or temperature < 0:
    sys.exit(3)
if not math.isfinite(timeout) or timeout <= 0:
    sys.exit(4)
PY
validation_rc=$?
set -e
case "$validation_rc" in
    0) ;;
    2) echo "Error: --temperature and --timeout must be numeric" >&2; exit 2 ;;
    3) echo "Error: --temperature must be a finite non-negative number" >&2; exit 2 ;;
    4) echo "Error: --timeout must be a positive number of seconds" >&2; exit 2 ;;
    *) echo "Error: option validation failed" >&2; exit 2 ;;
esac

question_chars=$(printf '%s' "$QUESTION" | wc -c | tr -d ' ')
if [ "$VERBOSE" -eq 1 ] || [ "$DRY_RUN" -eq 1 ]; then
    {
        echo "agent: model=${MODEL}"
        echo "agent: prompt_bytes=${question_chars} files=${#INPUT_FILES[@]} stdin_mode=${READ_STDIN}"
        echo "agent: max_tokens=${MAX_TOKENS} temperature=${TEMPERATURE} timeout=${REQUEST_TIMEOUT}"
    } >&2
fi

if [ "$DRY_RUN" -eq 1 ]; then
    printf '%s\n' "$QUESTION"
    exit 0
fi

if [ -z "${OPENROUTER_API_KEY:-}" ]; then
    echo "Error: OPENROUTER_API_KEY not set in ~/.secrets" >&2
    exit 1
fi

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT
printf '%s' "$QUESTION" > "$tmpdir/question.txt"
printf '%s' "$SYSTEM" > "$tmpdir/system.txt"

python3 - "$MODEL" "$TEMPERATURE" "$MAX_TOKENS" "$tmpdir/system.txt" "$tmpdir/question.txt" > "$tmpdir/payload.json" <<'PY'
import json
import sys

model, temperature, max_tokens, system_path, question_path = sys.argv[1:]
with open(system_path, encoding="utf-8") as f:
    system = f.read()
with open(question_path, encoding="utf-8") as f:
    question = f.read()
print(json.dumps({
    "model": model,
    "messages": [
        {"role": "system", "content": system},
        {"role": "user", "content": question},
    ],
    "temperature": float(temperature),
    "max_tokens": int(max_tokens),
}))
PY

http_code=$(curl -sS -o "$tmpdir/response.json" -w '%{http_code}' https://openrouter.ai/api/v1/chat/completions \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer ${OPENROUTER_API_KEY}" \
  -H "HTTP-Referer: https://claude.ai" \
  -H "X-Title: Claude Code" \
  --connect-timeout 10 \
  --max-time "$REQUEST_TIMEOUT" \
  --data-binary "@$tmpdir/payload.json")

python3 - "$http_code" "$MODEL" "$tmpdir/response.json" <<'PY'
import json
import sys

http_code, model, response_path = sys.argv[1:]
try:
    with open(response_path, encoding="utf-8") as f:
        data = json.load(f)
except Exception as exc:
    print(f"Error: OpenRouter returned non-JSON response (HTTP {http_code}) for {model}: {exc}", file=sys.stderr)
    with open(response_path, encoding="utf-8", errors="replace") as f:
        preview = f.read(1000).strip()
    if preview:
        print(preview, file=sys.stderr)
    sys.exit(1)

try:
    code = int(http_code)
except ValueError:
    code = 0
if code < 200 or code >= 300 or "error" in data:
    err = data.get("error", data)
    if isinstance(err, dict):
        msg = err.get("message") or err.get("code") or json.dumps(err)
    else:
        msg = str(err)
    print(f"Error: OpenRouter HTTP {http_code} for {model}: {msg}", file=sys.stderr)
    sys.exit(1)

try:
    content = data["choices"][0]["message"]["content"]
except Exception:
    print(f"Error: OpenRouter response missing choices for {model}: {json.dumps(data)[:1000]}", file=sys.stderr)
    sys.exit(1)

if content is None:
    content = ""
if content == "":
    print(f"Error: OpenRouter returned empty content for {model}", file=sys.stderr)
    sys.exit(1)
print(content)
PY
